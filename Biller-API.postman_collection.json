{
  "info": {
    "name": "Biller API",
    "description": "Monthly Biller API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Salary",
      "item": [
        {
          "name": "Set Default Salary",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 5000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/me/salary/default",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "salary", "default"]
            }
          }
        },
        {
          "name": "Set Monthly Salary",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 6000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/me/salary/2026/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "salary", "2026", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Commitments",
      "item": [
        {
          "name": "Set Default Commitments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commitments\": [\n    {\n      \"name\": \"Rent\",\n      \"type\": \"decimal\",\n      \"value\": 1200\n    },\n    {\n      \"name\": \"Savings\",\n      \"type\": \"percentage\",\n      \"value\": 20\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/me/commitments/default",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "commitments", "default"]
            }
          }
        },
        {
          "name": "Set Monthly Commitments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commitments\": [\n    {\n      \"name\": \"Car Loan\",\n      \"type\": \"decimal\",\n      \"value\": 800\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/me/commitments/2026/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "commitments", "2026", "1"]
            }
          }
        },
        {
          "name": "Update Commitment Paid Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_paid\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/me/commitments/2026/1/:commitment_id",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "users",
                "me",
                "commitments",
                "2026",
                "1",
                ":commitment_id"
              ],
              "variable": [
                {
                  "key": "commitment_id",
                  "value": "PUT_COMMITMENT_ID_HERE"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Summaries",
      "item": [
        {
          "name": "Get Monthly Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me/summary/monthly/2026/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "summary", "monthly", "2026", "1"]
            }
          }
        },
        {
          "name": "Get Yearly Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me/summary/yearly/2026",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me", "summary", "yearly", "2026"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newemail@example.com\",\n  \"default_salary\": 7000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/:user_id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":user_id"],
              "variable": [
                {
                  "key": "user_id",
                  "value": "PUT_USER_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/:user_id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":user_id"],
              "variable": [
                {
                  "key": "user_id",
                  "value": "PUT_USER_ID_HERE"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    }
  ]
}
